# OpenAI API Key (for embeddings and image description)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (for RAG answer generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_index_name_here

# Optional: Pinecone Environment (for older accounts)
# PINECONE_ENVIRONMENT=us-east-1-aws

# MSDS API Key (KOSHA - 산업안전보건공단)
# Get your API key from: https://www.data.go.kr/data/15040071/openapi.do
MSDS_API_KEY=your_msds_api_key_here

# Law Search API (고용노동부 법령 내용 - api.odcloud.kr)
# Get your API key from: https://www.data.go.kr/data/15072614/fileData.do
# Used to enrich laborlaw AI answers with official law references
LAW_API_KEY=your_law_api_key_here

# RAG Pipeline Options
# USE_LOCAL_RERANKER=true    # Force local cross-encoder instead of Pinecone Inference API
# SKIP_BM25_HYBRID=true      # Skip BM25+RRF step (use when Pinecone reranker is active)

# RAG Quality Tuning (optional, defaults shown)
# MIN_RELEVANCE_SCORE=0.3    # Minimum vector similarity score to include a chunk
# MIN_TOKEN_COUNT=30         # Minimum token count; filters out noise/near-empty chunks

# Hybrid Search Tuning
# RRF_K=60                   # RRF constant (higher = lower rank penalty)
# KEYWORD_BOOST=0.1          # Base boost per keyword match in content
# TITLE_BOOST=3.0            # Multiplier when keyword matches document_title
# SECTION_BOOST=2.0          # Multiplier when keyword matches section_title

# Reranker Weights
# RERANK_WEIGHT=0.7          # Weight for cross-encoder rerank score
# ORIGINAL_WEIGHT=0.3        # Weight for original retrieval score

# top_k Fetch Multipliers (how many candidates to fetch before reranking)
# TOP_K_MENTION_MULT=3       # Multiplier when @mention filter is used
# TOP_K_NO_BM25_MULT=4       # Multiplier when BM25 is skipped (SKIP_BM25_HYBRID=true)
# TOP_K_DEFAULT_MULT=2       # Default multiplier

# Database: SQLite (instance/app.db) - no configuration needed

# OAuth Social Login
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Kakao: https://developers.kakao.com/console/app
KAKAO_CLIENT_ID=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here

# Anthropic Claude API Key (for RAG answer generation + contextual retrieval)
# Also used by: python main.py process --contextual (LLM-based chunk context generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CONTEXT_MODEL=claude-haiku-4-5-20251001   # Model for contextual prefix generation
# CONTEXT_CACHE_ENABLED=true                # SQLite cache for generated prefixes

# Flask
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
# FLASK_ENV=production  # Set to 'production' or 'prod' for production mode

# Rate Limiting (requires flask-limiter: pip install flask-limiter)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_STORAGE_URI=redis://localhost:6379  # Default: memory:// (per-worker)

# CORS - comma-separated allowed origins (omit for same-origin only)
# CORS_ORIGINS=https://example.com,https://www.example.com
